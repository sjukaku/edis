{
	"name": "Salesforce SCD 6 load",
	"properties": {
		"description": "Load all tables from salesforce to edis-salesforce-raw container by creating appropriate directories",
		"activities": [
			{
				"name": "load_each_table",
				"description": "Load each table from ODS_corporate_finance db to edis-gold container. degree of parallelism is set to 10 and file name is a utc timestamp.",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "retrieve_table_list",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('retrieve_table_list').output.value",
						"type": "Expression"
					},
					"batchCount": 10,
					"activities": [
						{
							"name": "Copy given table data from ods to edis-gold",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.00:45:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [
								{
									"name": "Source",
									"value": "@{item().API_Name}"
								}
							],
							"typeProperties": {
								"source": {
									"type": "SalesforceSource",
									"additionalColumns": [
										{
											"name": "Extraction_datetime",
											"value": {
												"value": "@utcnow()",
												"type": "Expression"
											}
										}
									],
									"readBehavior": "queryAll"
								},
								"sink": {
									"type": "ParquetSink",
									"storeSettings": {
										"type": "AzureBlobStorageWriteSettings"
									},
									"formatSettings": {
										"type": "ParquetWriteSettings"
									}
								},
								"enableStaging": false,
								"parallelCopies": 10,
								"validateDataConsistency": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "SalesforceObject",
									"type": "DatasetReference",
									"parameters": {
										"TableName": {
											"value": "@item().API_Name",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "sink_edisdatalake",
									"type": "DatasetReference",
									"parameters": {
										"FileName": {
											"value": "@item().Label",
											"type": "Expression"
										},
										"ContainerName": {
											"value": "@pipeline().parameters.sink_container",
											"type": "Expression"
										},
										"Directory": {
											"value": "@pipeline().parameters.sink_directory",
											"type": "Expression"
										}
									}
								}
							]
						}
					]
				}
			},
			{
				"name": "retrieve_table_list",
				"description": "Lookup and retrieve table list from ods_corporate_finance db",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureDatabricksDeltaLakeSource"
					},
					"dataset": {
						"referenceName": "AzureDatabricksDeltaLakeDataset",
						"type": "DatasetReference",
						"parameters": {
							"databasename": "salesforce_bronze",
							"tablename": "salesforce_objects"
						}
					},
					"firstRowOnly": false
				}
			}
		],
		"parameters": {
			"sink_container": {
				"type": "string",
				"defaultValue": "edis-raw"
			},
			"sink_directory": {
				"type": "string",
				"defaultValue": "sf"
			}
		},
		"annotations": [],
		"lastPublishTime": "2022-04-09T09:05:10Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}